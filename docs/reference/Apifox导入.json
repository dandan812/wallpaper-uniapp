{
  "openapi": "3.0.3",
  "info": {
    "title": "Wallpaper API",
    "description": "OpenAPI definition generated from the current backend routes for Apifox import.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://8.135.46.112/api",
      "description": "production"
    },
    {
      "url": "http://localhost:3000/api",
      "description": "local"
    }
  ],
  "security": [
    {
      "accessKeyAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "accessKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "access-key",
        "description": "API access key, for example key123456"
      }
    },
    "schemas": {
      "ApiResponseBase": {
        "type": "object",
        "properties": {
          "errCode": {
            "type": "integer",
            "example": 0
          },
          "errMsg": {
            "type": "string",
            "example": "success"
          },
          "timeCost": {
            "type": "integer",
            "example": 0
          },
          "total": {
            "type": "integer",
            "nullable": true,
            "example": 3
          }
        }
      },
      "CategoryItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "_id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "cute-pets"
          },
          "picurl": {
            "type": "string",
            "example": "https://picsum.photos/id/1025/480/854"
          },
          "sort": {
            "type": "integer",
            "example": 1
          },
          "select": {
            "type": "integer",
            "example": 1
          },
          "wallpaper_count": {
            "type": "integer",
            "example": 2
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "updateTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "BannerItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "_id": {
            "type": "integer",
            "example": 1
          },
          "picurl": {
            "type": "string",
            "example": "https://example.com/banner.jpg"
          },
          "target": {
            "type": "string",
            "example": "miniProgram"
          },
          "url": {
            "type": "string",
            "example": "/pages/classlist/classlist?id=1&name=cute-pets"
          },
          "appid": {
            "type": "string",
            "nullable": true,
            "example": "wx123456"
          }
        }
      },
      "NoticeItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "_id": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "welcome-notice"
          },
          "content": {
            "type": "string",
            "example": "<p>notice content</p>"
          },
          "view_count": {
            "type": "integer",
            "example": 12
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "WallpaperSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "_id": {
            "type": "integer",
            "example": 1
          },
          "classid": {
            "type": "integer",
            "example": 1
          },
          "smallPicurl": {
            "type": "string",
            "example": "https://picsum.photos/id/1025/480/854"
          },
          "score": {
            "type": "string",
            "example": "4.8"
          },
          "title": {
            "type": "string",
            "nullable": true,
            "example": "sample-wallpaper"
          }
        }
      },
      "WallpaperDetail": {
        "allOf": [
          {
            "$ref": "#/components/schemas/WallpaperSummary"
          },
          {
            "type": "object",
            "properties": {
              "picurl": {
                "type": "string",
                "example": "https://picsum.photos/id/1025/1440/2560"
              },
              "description": {
                "type": "string",
                "example": "sample wallpaper description"
              },
              "tabs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "example": [
                  "pet",
                  "healing",
                  "cat"
                ]
              },
              "score_count": {
                "type": "integer",
                "example": 36
              },
              "download_count": {
                "type": "integer",
                "example": 128
              },
              "view_count": {
                "type": "integer",
                "example": 525
              },
              "nickname": {
                "type": "string",
                "example": "sample-user"
              },
              "status": {
                "type": "integer",
                "example": 1
              },
              "created_at": {
                "type": "string",
                "format": "date-time"
              },
              "updated_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        ]
      },
      "UserInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "nickname": {
            "type": "string",
            "example": "test-user"
          },
          "avatar": {
            "type": "string",
            "example": ""
          },
          "openid": {
            "type": "string",
            "example": "test_openid_001"
          },
          "IP": {
            "type": "string",
            "example": "127.0.0.1"
          },
          "address": {
            "type": "object",
            "properties": {
              "country": {
                "type": "string",
                "example": "local"
              },
              "province": {
                "type": "string",
                "example": "local"
              },
              "city": {
                "type": "string",
                "example": "local"
              }
            }
          },
          "scoreSize": {
            "type": "integer",
            "example": 0
          },
          "downloadSize": {
            "type": "integer",
            "example": 0
          },
          "score_count": {
            "type": "integer",
            "example": 0
          },
          "download_count": {
            "type": "integer",
            "example": 0
          }
        }
      },
      "ScoreRequest": {
        "type": "object",
        "required": [
          "userId",
          "wallpaperId",
          "score"
        ],
        "properties": {
          "userId": {
            "type": "integer",
            "example": 1
          },
          "wallpaperId": {
            "type": "integer",
            "example": 1
          },
          "score": {
            "type": "number",
            "example": 4.5
          }
        }
      },
      "DownloadRequest": {
        "type": "object",
        "required": [
          "userId",
          "wallpaperId"
        ],
        "properties": {
          "userId": {
            "type": "integer",
            "example": 1
          },
          "wallpaperId": {
            "type": "integer",
            "example": 1
          }
        }
      },
      "ApiResponseCategoryList": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ApiResponseBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CategoryItem"
                }
              }
            }
          }
        ]
      },
      "ApiResponseBannerList": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ApiResponseBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/BannerItem"
                }
              }
            }
          }
        ]
      },
      "ApiResponseNoticeList": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ApiResponseBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/NoticeItem"
                }
              }
            }
          }
        ]
      },
      "ApiResponseNoticeDetail": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ApiResponseBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/NoticeItem"
              }
            }
          }
        ]
      },
      "ApiResponseWallpaperList": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ApiResponseBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/WallpaperSummary"
                }
              }
            }
          }
        ]
      },
      "ApiResponseWallpaperDetail": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ApiResponseBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/WallpaperDetail"
              }
            }
          }
        ]
      },
      "ApiResponseUserInfo": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ApiResponseBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/UserInfo"
              }
            }
          }
        ]
      },
      "ApiResponseScore": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ApiResponseBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "score": {
                    "type": "number",
                    "example": 4.5
                  }
                }
              }
            }
          }
        ]
      },
      "ApiResponseNull": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ApiResponseBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "nullable": true,
                "example": null
              }
            }
          }
        ]
      }
    }
  },
  "paths": {
